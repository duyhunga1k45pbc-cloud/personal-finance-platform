cat > .gitignore <<'EOF'
# Python virtual environment
venv/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Pytest
.pytest_cache/

# Environment files
.env
.env.*

# Old/temp files
old_main.py
old_database.py
pytest_error.txt

# OS
.DS_Store
Thumbs.db
EOF
# Environment files
.env
.env.*
!.env.example